# Copy this file to backend/.env and fill in real values.
# NEVER commit the real .env -- it is listed in .gitignore.

# Google Maps Routes API key (server-side only, never exposed to frontend).
GOOGLE_MAPS_API_KEY=your-maps-api-key

# Gemini API key (used only to phrase a one-line tip).
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Google Cloud project that owns the Firestore database.
GCP_PROJECT_ID=your-gcp-project-id
FIRESTORE_COLLECTION=greenroute_logs

# Comma-separated list of allowed frontend origins for CORS.
# Example: https://your-app.web.app
ALLOWED_ORIGINS=*

# Rate limit for the comparison endpoint.
RATE_LIMIT_MAX_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60
